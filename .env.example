# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ──────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────
POSTGRES_USER=booking
POSTGRES_PASSWORD=booking
POSTGRES_PORT=5432

# Per-service JDBC URLs (used by Spring Boot services)
USER_DB_URL=jdbc:postgresql://localhost:5432/userdb
MOVIE_DB_URL=jdbc:postgresql://localhost:5432/moviedb
THEATRE_DB_URL=jdbc:postgresql://localhost:5432/theatredb
SHOW_DB_URL=jdbc:postgresql://localhost:5432/showdb
BOOKING_DB_URL=jdbc:postgresql://localhost:5432/bookingdb
PAYMENT_DB_URL=jdbc:postgresql://localhost:5432/paymentdb
OFFER_DB_URL=jdbc:postgresql://localhost:5432/offerdb

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis

# ──────────────────────────────────────────────
# Kafka
# ──────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_PORT=9092

# ──────────────────────────────────────────────
# Elasticsearch
# ──────────────────────────────────────────────
ES_HOST=localhost
ES_PORT=9200
ES_URL=http://localhost:9200

# ──────────────────────────────────────────────
# Mail (MailHog for local)
# ──────────────────────────────────────────────
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ──────────────────────────────────────────────
# JWT / Auth
# ──────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRATION_MS=86400000

# ──────────────────────────────────────────────
# Payment gateway (stub values for local)
# ──────────────────────────────────────────────
PAYMENT_GATEWAY_URL=http://localhost:8099
PAYMENT_GATEWAY_API_KEY=local-test-key
